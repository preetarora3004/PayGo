generator client {
   provider = "prisma-client-js"
}

datasource db {
   provider = "postgresql"
}

enum Status {
   APPROVED
   FAILED
   PENDING
}

enum Role {
   Customer
   Admin
   Analyst
}

enum Approval {
   APPROVED
   REJECT
   PENDING
}

model User {
   id       String @id @default(cuid())
   email    String @unique
   name     String
   password String

   role      Role
   admin     Admin?
   customer  Customer?
   analyst   Analyst?
   ticket    Ticket?
   isDeleted Boolean   @default(false)

   updatedAt DateTime @updatedAt()
   createdAt DateTime @default(now())
}

model Ticket {
   id     String @id @default(cuid())
   role   Role   @default(Customer)
   status Status @default(FAILED)

   userId String @unique
   user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

   isApproved Approval @default(PENDING)
   isStaff    Boolean  @default(false)
   createdAt  DateTime @default(now())
   updatedAt  DateTime @updatedAt()
}

model Admin {
   id String @id @default(cuid())

   userId String @unique
   user   User   @relation(fields: [userId], references: [id])

   createdAt DateTime @default(now())
}

model Analyst {
   id String @id @default(cuid())

   userId String @unique
   user   User   @relation(fields: [userId], references: [id])

   createdAt  DateTime @default(now())
   isCustomer Boolean  @default(false)
}

model Customer {
   id String @id @default(cuid())

   userId String @unique
   user   User   @relation(fields: [userId], references: [id])

   bankAccount BankAccount?
   flag        Boolean      @default(false)
}

model BankAccount {
   id                String @id @default(cuid())
   bankAccountNumber BigInt @unique
   funds             Int    @default(5000)

   customerId String   @unique
   customer   Customer @relation(fields: [customerId], references: [id])

   transactions Transaction[]
}

model Transaction {
   id         String @id @default(cuid())
   funds      Int
   senderId   String
   receiverId String
   status     Status @default(FAILED)

   bankAccountNumber BigInt
   bankAccount       BankAccount @relation(fields: [bankAccountNumber], references: [bankAccountNumber])

   date DateTime @default(now())

   @@index([senderId])
}
